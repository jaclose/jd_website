# Site URL (used for metadata / OG tags in production)
NEXT_PUBLIC_SITE_URL=https://jafardabbagh.com

# Formspree form ID for the contact form
# Get yours at https://formspree.io
NEXT_PUBLIC_FORMSPREE_ID=YOUR_FORM_ID
